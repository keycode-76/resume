{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "pocony.dollarbasellc.com"
        }
      ],
      "destination": "/pocony/$1"
    },
    {
      "source": "/",
      "has": [
        {
          "type": "host",
          "value": "pocony.dollarbasellc.com"
        }
      ],
      "destination": "/pocony/index.html"
    }
  ]
}