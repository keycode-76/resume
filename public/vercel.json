{
  "version": 2,
  "rewrites": [
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "pocony.dollarbasellc.com"
        }
      ],
      "destination": "/pocony/$1"
    },
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "challog.dollarbasellc.com"
        }
      ],
      "destination": "/challog/$1"
    }
  ]
}
